DATABASE_URL="postgresql://travel_app_user:YOUR_ENCODED_PASSWORD@YOUR_SERVER.postgres.database.azure.com:5432/travel_app?sslmode=require"
DIRECT_URL="postgresql://travel_app_user:YOUR_ENCODED_PASSWORD@YOUR_SERVER.postgres.database.azure.com:5432/travel_app?sslmode=require"

APP_NAME="Travel App"
JWT_SECRET="change-me-to-long-random-string"
NODE_ENV="production"
PORT=8000
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Travel App <no-reply@example.com>"

# Public backend URL used to generate absolute upload links for the mobile app.
PUBLIC_BASE_URL="https://your-api-domain.example.com"

# Local upload storage on VPS / Coolify persistent volume.
UPLOADS_DIR="uploads"

# Optional. Comma-separated web origins for CORS. Native mobile apps can leave this empty.
ALLOWED_ORIGINS=""

# Set to true behind Coolify / reverse proxies so Express trusts X-Forwarded-* headers.
TRUST_PROXY="true"
