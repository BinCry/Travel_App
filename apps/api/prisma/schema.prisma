generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PlaceCategory {
  ATTRACTIONS
  DINING
  FESTIVALS
}

enum UserRole {
  TRAVELER
  OWNER
}

enum BookingStatus {
  DRAFT
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
  NO_SHOW
  REFUND_PENDING
  REFUNDED
}

model User {
  id                    Int                    @id @default(autoincrement())
  email                 String                 @unique
  passwordHash          String
  role                  UserRole               @default(TRAVELER)
  fullName              String?
  username              String?                @unique
  location              String?
  avatarUrl             String?
  emailVerifiedAt       DateTime?
  createdAt             DateTime               @default(now())
  reviews               Review[]
  reviewReplies         ReviewReply[]
  reviewLikes           ReviewLike[]
  favorites             Favorite[]
  collections           Collection[]
  notifications         Notification[]
  trips                 Trip[]
  bookings              Booking[]
  ownedPlaces           Place[]
  placeUpdates          PlaceUpdate[]
  passwordResetOtps     PasswordResetOtp[]
  emailVerificationOtps EmailVerificationOtp[]
}

model PasswordResetOtp {
  id         String    @id @default(cuid())
  userId     Int?
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  verifiedAt DateTime?
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model EmailVerificationOtp {
  id         String   @id @default(cuid())
  userId     Int
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

model Place {
  id               String       @id @default(cuid())
  ownerId          Int?
  name             String
  region           String
  category         PlaceCategory
  coverImageUrl    String
  featureLabel     String
  averageRating    Float        @default(0)
  ratingCount      Int          @default(0)
  about            String       @default("")
  priceLevel       Float?
  latitude         Float?
  longitude        Float?
  owner            User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  reviews          Review[]
  favorites        Favorite[]
  collectionEntries CollectionPlace[]
  promotions       Promotion[]
  updates          PlaceUpdate[]
  bookingOptions   BookingOption[]
  bookings         Booking[]
}

model Collection {
  id        String            @id @default(cuid())
  userId    Int
  title     String
  isPublic  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  places    CollectionPlace[]

  @@index([userId, createdAt(sort: Desc)])
}

model CollectionPlace {
  collectionId String
  placeId      String
  addedAt      DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  place        Place      @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([collectionId, placeId])
  @@index([placeId])
}

model Promotion {
  id           String   @id @default(cuid())
  placeId      String
  title        String
  isActive     Boolean  @default(true)
  startDate    String
  endDate      String
  days         String[]
  startTime    String   @default("")
  endTime      String   @default("")
  specificTime Boolean  @default(false)
  createdAt    DateTime @default(now())
  place        Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Review {
  id        String       @id @default(cuid())
  placeId   String
  userId    Int
  rating    Int
  content   String
  createdAt DateTime     @default(now())
  place     Place        @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  images    ReviewImage[]
  likes     ReviewLike[]
  reply     ReviewReply?
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  ownerId   Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  url      String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model ReviewLike {
  id        Int    @id @default(autoincrement())
  reviewId  String
  userId    Int
  review    Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model Favorite {
  userId  Int
  placeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  place   Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@id([userId, placeId])
}

model PlaceUpdate {
  id        String   @id @default(cuid())
  placeId    String
  ownerId    Int
  title      String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  place      Place    @relation(fields: [placeId], references: [id], onDelete: Cascade)
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([placeId, createdAt(sort: Desc)])
  @@index([ownerId, createdAt(sort: Desc)])
}

model Notification {
  id        String    @id @default(cuid())
  userId     Int
  type       String
  title      String
  message    String
  payload    Json?
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
}

model Trip {
  id          String     @id @default(cuid())
  userId      Int
  title       String
  destination String
  startDate   DateTime?
  endDate     DateTime?
  budget      String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops       TripStop[]

  @@index([userId, createdAt(sort: Desc)])
}

model TripStop {
  id         String   @id @default(cuid())
  tripId     String
  dayNumber  Int      @default(1)
  orderIndex Int
  title      String
  location   String?
  note       String?
  startTime  String?
  endTime    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, dayNumber, orderIndex])
  @@unique([tripId, dayNumber, orderIndex])
}

model BookingOption {
  id              String             @id @default(cuid())
  placeId          String
  title            String
  description      String?
  priceLabel       String?
  durationMinutes  Int                @default(90)
  maxPartySize     Int                @default(2)
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  place            Place              @relation(fields: [placeId], references: [id], onDelete: Cascade)
  slots            AvailabilitySlot[]
  bookings         Booking[]

  @@index([placeId, createdAt(sort: Desc)])
}

model AvailabilitySlot {
  id         String         @id @default(cuid())
  optionId    String
  startAt     DateTime
  endAt       DateTime
  capacity    Int
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  option      BookingOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@index([optionId, startAt])
}

model Booking {
  id          String         @id @default(cuid())
  placeId      String
  optionId     String
  slotId       String
  travelerId   Int
  partySize    Int
  note         String?
  status       BookingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cancelledAt  DateTime?
  place        Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  option       BookingOption @relation(fields: [optionId], references: [id], onDelete: Restrict)
  slot         AvailabilitySlot @relation(fields: [slotId], references: [id], onDelete: Restrict)
  traveler     User          @relation(fields: [travelerId], references: [id], onDelete: Cascade)

  @@index([travelerId, createdAt(sort: Desc)])
  @@index([placeId, createdAt(sort: Desc)])
  @@index([slotId, status])
}
