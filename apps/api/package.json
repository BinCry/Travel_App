{
  "name": "@travel-app/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "npm --prefix ../../packages/shared run build",
    "pretest": "npm --prefix ../../packages/shared run build",
    "pretest:db": "node -e \"if (!process.env.DATABASE_URL) { throw new Error('DATABASE_URL là bắt buộc cho test:db'); }\" && npm --prefix ../../packages/shared run build",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "npm run db:migrate:deploy && node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.mjs",
    "db:seed:rich": "node prisma/seed.mjs",
    "db:audit:consistency": "node scripts/database/audit-consistency.mjs",
    "db:create-test-accounts": "node scripts/database/create-test-accounts.mjs",
    "db:local:up": "docker compose -f docker-compose.local.yml up -d",
    "db:local:down": "docker compose -f docker-compose.local.yml down",
    "db:local:reset": "docker compose -f docker-compose.local.yml down -v",
    "db:local:logs": "docker compose -f docker-compose.local.yml logs -f postgres",
    "db:studio": "prisma studio",
    "db:sync": "prisma generate && prisma db push && npm run db:seed",
    "storage:verify": "tsx scripts/verify-storage.ts",
    "openapi:write": "tsx scripts/write-openapi.ts",
    "db:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:db": "vitest run --config vitest.db.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@prisma/client": "^6.14.0",
    "@travel-app/shared": "*",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.5",
    "prisma": "^6.14.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.5",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^6.4.17",
    "@types/node": "^22.15.32",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
