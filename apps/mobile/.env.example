# Recommended for Expo LAN local development on a physical device.
# The app will reuse the same host IP that Expo is serving from.
#
# Android emulator: http://10.0.2.2:8000
# iOS simulator / web: http://localhost:8000
# Physical device on the same LAN: http://<your-lan-ip>:8000
# Azure VPS / Coolify deployment: https://your-api-domain.example.com
# EAS Android preview/production builds must point to the public HTTPS API.
EXPO_PUBLIC_API_BASE_URL=auto
