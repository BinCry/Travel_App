{
  "name": "travel-app-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm --prefix packages/shared run build",
    "build:shared": "npm --prefix packages/shared run build",
    "build:api": "npm --prefix apps/api run build",
    "dev:api": "npm --prefix apps/api run dev",
    "start:mobile:lan": "npm --prefix apps/mobile run start:lan",
    "test:api": "npm --prefix apps/api run test",
    "test:api:db": "npm --prefix apps/api run test:db",
    "typecheck:mobile": "npm --prefix apps/mobile run typecheck",
    "lint:mobile": "npm --prefix apps/mobile run lint",
    "test:mobile": "npm --prefix apps/mobile run test",
    "verify:api": "npm run build:shared && npm run build:api && npm run test:api",
    "verify:api:db": "npm run build:shared && npm run build:api && npm run test:api:db",
    "verify:mobile": "npm run build:shared && npm run typecheck:mobile && npm run lint:mobile",
    "verify:storage": "npm --prefix apps/api run storage:verify",
    "mobile:lint": "npm run lint:mobile"
  }
}
