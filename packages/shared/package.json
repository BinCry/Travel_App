    "./common": {
      "types": "./dist/common.d.ts",
      "default": "./dist/common.js"
    },
    "./contracts/auth": {
      "types": "./dist/contracts/auth.d.ts",
      "default": "./dist/contracts/auth.js"
    },
    "./contracts/owner": {
      "types": "./dist/contracts/owner.d.ts",
      "default": "./dist/contracts/owner.js"
    },
    "./contracts/places": {
      "types": "./dist/contracts/places.d.ts",
      "default": "./dist/contracts/places.js"
    },
    "./contracts/reviews": {
      "types": "./dist/contracts/reviews.d.ts",
      "default": "./dist/contracts/reviews.js"
    },
    "./contracts/bookings": {
      "types": "./dist/contracts/bookings.d.ts",
      "default": "./dist/contracts/bookings.js"
    },
    "./contracts/trips": {
      "types": "./dist/contracts/trips.d.ts",
      "default": "./dist/contracts/trips.js"
    },
    "./contracts/uploads": {
      "types": "./dist/contracts/uploads.d.ts",
